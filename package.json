{
  "name": "tsgo-strict-repo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for tsgo-strict (Rust CLI + npm launcher + per-platform binaries)",
  "license": "MIT",
  "packageManager": "pnpm@10.10.0",
  "workspaces": [
    "npm/tsgo-strict",
    "npm/platforms/*"
  ],
  "scripts": {
    "build": "cargo build --release",
    "test": "cargo test --workspace",
    "test:node": "bash scripts/stage-local-addon.sh && node --test npm/tsgo-strict/test/napi.test.mjs",
    "fmt": "cargo fmt --all",
    "fmt:check": "cargo fmt --all -- --check",
    "lint": "cargo clippy --workspace --all-targets -- -D warnings",
    "perf:generate": "node perf-demo/scripts/generate.mjs",
    "perf:check": "target/release/tsgo-strict --project perf-demo/tsconfig.json",
    "perf:subset": "target/release/tsgo-strict perf-demo/src/batch-00 --project perf-demo/tsconfig.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "vitepress": "^1.6.4"
  }
}
