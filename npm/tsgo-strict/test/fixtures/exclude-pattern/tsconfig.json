{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "typescript-strict-plugin",
        "excludePattern": ["\\.spec\\.ts$", "\\.test\\.ts$", "\\.stories\\.ts$"]
      }
    ]
  },
  "include": ["src/**/*"]
}
